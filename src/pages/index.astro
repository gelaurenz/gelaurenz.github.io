---
import BaseLayout from "../layouts/BaseLayout.astro";

const site = {
  name: "Laurenz Gebauer",
  role: "UX & Product Designer",
  location: "Austria",
  summary:
    "UX- & product designer, researcher, and prototype engineer designing intuitive interfaces for products that reach millions of customers.",
  intro:
    "I hold a Master of Science in Human-Centered Computing from the University of Applied Sciences Hagenberg. I design engaging digital products with a focus on usability, clarity, and the kind of interaction quality that helps teams ship with confidence.",
  mission:
    "My aim is to create products that not only function well but also bring joy and inspiration. I am especially motivated by the intersection of technology, design, and human insight.",
  availability:
    "Open to UX design, product design, research, and prototyping collaborations.",
  contactLinks: [
    {
      label: "Email",
      href: "mailto:laurenz.gebauer@gmx.at"
    },
    {
      label: "Call",
      href: "tel:+436606422328"
    },
    {
      label: "GitHub",
      href: "https://github.com/gelaurenz"
    },
    {
      label: "Figma Portfolio",
      href: "https://www.figma.com/design/M1Gy1R4VKp6XwEXmrMCcYI/Gebauer-L.--Portfolio?node-id=328-22996&t=Nkl4n2Rei7qcDgh8-1"
    }
  ],
  profileHighlights: [
    "UX & Product Designer",
    "Researcher",
    "Prototype Engineer"
  ],
  aboutParagraphs: [
    "I have been designing engaging and intuitive user interfaces for products that delight millions of customers. I bring usability, creativity, and teamwork into every project, always looking for ways to increase product maturity and make experiences easier to understand.",
    "In this portfolio, you will find examples of previous work, design methods, and the process techniques I use to move from insight to interface. I care about turning complexity into momentum and making products feel thoughtful from the first interaction."
  ]
};

const heroFacts = [
  { label: "Education", value: "MSc Human-Centered Computing" },
  { label: "Focus", value: "Research, product design, prototyping" },
  { label: "Base", value: "Austria" }
];

const heroSignals = [
  "Products used by millions",
  "Research-to-prototype workflow",
  "Interfaces with clarity and momentum"
];

const projectPreviews = [
  {
    eyebrow: "E-Commerce",
    title: "Travel portal and companion apps",
    description:
      "Responsible for designing a web portal and associated Android and iOS apps used by more than 2 million customers.",
    tags: ["Web portal", "Android + iOS", "2M+ downloads"],
    image: "/images/work/case-marketplace.png",
    imageAlt: "Travel booking product shown across mobile and web interfaces",
    art: "commerce"
  },
  {
    eyebrow: "Lean Design",
    title: "Online challenge platform",
    description:
      "Led the development of an online platform facilitating the creation, sharing, and participation in online challenges.",
    tags: ["Challenge flows", "Mobile-first", "Content systems"],
    art: "lean"
  },
  {
    eyebrow: "Gamification",
    title: "Interactive tour application",
    description:
      "Developed and designed a mobile application for interactive tours on Android platforms with a more playful exploration model.",
    tags: ["Android", "Gamified UX", "Interactive tours"],
    art: "game"
  }
];

const methods = [
  {
    eyebrow: "User experience",
    title: "Usability testing",
    body:
      "I validate design assumptions from review cycles and stakeholder discussions through structured testing and attitudinal metrics. Depending on the project, I use SUS, SUPR-Q, UEQ, CSAT, SMEQ, and direct customer feedback to understand where the experience succeeds and where it still creates friction."
  },
  {
    eyebrow: "User experience",
    title: "Prototyping",
    body:
      "I create prototypes of varying fidelity to capture design concepts and test them with users early. Through prototyping, I refine requirements, reduce risk, and help teams release the right product with more clarity. My workflow regularly includes Figma and ProtoPie."
  }
];

const currentCaseStudy = {
  title: "School of UX Booking Experience",
  eyebrow: "Current detailed case study",
  summary:
    "A responsive case-study build focused on research, journey clarity, accessibility, usability testing, and handover.",
  tags: ["Research-led", "Journey mapping", "Accessibility", "Testing"],
  href: "/work/school-of-ux-booking/"
};

---

<BaseLayout
  title="Laurenz Gebauer | UX Portfolio"
  description="Responsive UX portfolio for Laurenz Gebauer featuring product thinking, research, prototyping, and case-study storytelling."
  path="/"
>
  <section class="hero-grid hero-grid-signature panel" data-reveal>
    <div class="hero-stage">
      <p class="hero-stage-kicker">Available for product design roles</p>
      <div class="hero-stage-badge">LG</div>
      <h2 class="hero-stage-heading">
        Research-driven design for products that need clarity, confidence, and momentum.
      </h2>
      <p class="hero-stage-copy">
        From large-scale commerce to lean digital products, I design interfaces that translate
        complexity into experiences people can actually use.
      </p>

      <ul class="hero-stage-signals" aria-label="Key strengths">
        {heroSignals.map((signal) => <li>{signal}</li>)}
      </ul>

      <div class="hero-stage-foot">
        <span>{site.location}</span>
        <span>{site.role}</span>
      </div>
    </div>

    <div class="hero-copy">
      <p class="eyebrow">UX portfolio</p>
      <h1>
        Hi, I&apos;m <span>{site.name}</span>
      </h1>
      <p class="lede">{site.summary}</p>
      <p class="supporting-copy">{site.intro}</p>
      <p class="supporting-copy">{site.mission}</p>

      <div class="button-row">
        <a href="#work" class="button button-primary">See selected work</a>
        <a href="#contact" class="button button-secondary">Hire me</a>
      </div>

      <ul class="hero-meta" aria-label="Portfolio details">
        <li>{site.role}</li>
        <li>{site.location}</li>
        <li>{site.availability}</li>
      </ul>

      <ul class="hero-meta hero-meta-roles" aria-label="Discipline highlights">
        {site.profileHighlights.map((item) => <li>{item}</li>)}
      </ul>

      <div class="hero-facts-grid">
        {heroFacts.map((fact) => (
          <article class="hero-fact-card">
            <span>{fact.label}</span>
            <p>{fact.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="work" class="panel section-space" data-reveal>
    <div class="section-intro">
      <p class="eyebrow">Projects</p>
      <h2>Product work across commerce, challenge systems, and gamified mobile experiences.</h2>
      <p>
        These previews are drawn from your portfolio material and show the breadth of your work:
        large-scale commerce flows, lean platform design, and interaction-heavy mobile concepts.
      </p>
    </div>

    <div class="project-grid project-grid-featured">
      {projectPreviews.map((project) => (
        <article class="project-card project-card-preview">
          {project.image ? (
            <div class="project-image-shell">
              <img src={project.image} alt={project.imageAlt ?? ""} class="project-image" loading="lazy" />
            </div>
          ) : (
            <div class={`project-image-shell project-poster project-poster-${project.art}`}>
              <div class="project-poster-stack">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          )}

          <div class="project-body">
            <p class="eyebrow">{project.eyebrow}</p>
            <h3>{project.title}</h3>
            <p>{project.description}</p>

            <ul class="tag-list" aria-label={`${project.title} tags`}>
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>

            <span class="text-link muted-label">Detailed case study coming next</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="about" class="about-grid section-space" data-reveal>
    <article class="panel">
      <p class="eyebrow">About</p>
      <h2>Creating products that combine usability, clarity, and joy.</h2>
      {site.aboutParagraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </article>

    <aside class="panel panel-contrast">
      <p class="eyebrow">Quick profile</p>
      <ul class="facts">
        <li><strong>Role:</strong> {site.role}</li>
        <li><strong>Base:</strong> {site.location}</li>
        <li><strong>Education:</strong> MSc in Human-Centered Computing</li>
        <li><strong>Strengths:</strong> Research, interaction design, prototyping</li>
        <li><strong>Mindset:</strong> Clear systems, engaging flows, better decisions</li>
      </ul>
    </aside>
  </section>

  <section id="approach" class="panel section-space" data-reveal>
    <div class="section-intro">
      <p class="eyebrow">Methods</p>
      <h2>Research, testing, and prototyping are part of the product work, not a separate layer.</h2>
    </div>

    <div class="principles-grid methods-grid">
      {methods.map((method, index) => (
        <article class="principle-card method-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p class="eyebrow eyebrow-inline">{method.eyebrow}</p>
          <h3>{method.title}</h3>
          <p>{method.body}</p>
        </article>
      ))}

      <article class="principle-card method-card method-card-accent">
        <span>03</span>
        <p class="eyebrow eyebrow-inline">Portfolio build</p>
        <h3>Case studies that read like product stories.</h3>
        <p>
          The site is structured to show context, design reasoning, testing, accessibility, and
          implementation readiness instead of relying on static mockups alone.
        </p>
      </article>
    </div>
  </section>

  <section class="panel case-study-preview section-space" data-reveal>
    <div class="section-intro">
      <p class="eyebrow">{currentCaseStudy.eyebrow}</p>
      <h2>{currentCaseStudy.title}</h2>
      <p>{currentCaseStudy.summary}</p>
    </div>

    <div class="current-case-study">
      <ul class="tag-list" aria-label="Current case study tags">
        {currentCaseStudy.tags.map((tag) => <li>{tag}</li>)}
      </ul>

      <a href={currentCaseStudy.href} class="button button-primary">
        Read the current case study
      </a>
    </div>
  </section>

  <section id="contact" class="panel contact-panel section-space" data-reveal>
    <p class="eyebrow">Contact</p>
    <h2>Hire me.</h2>
    <p>
      An experience designer with a dream to use the power of human insight and interactions to
      spark the full creative potential of every project I am involved in.
    </p>

    <div class="contact-links">
      {site.contactLinks.map((link) => (
        <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>

    <p class="contact-signoff">
      Gebauer Laurenz
      <br />
      UX- & Product Designer
      <br />
      +43 660 642 232 8
      <br />
      laurenz.gebauer@gmx.at
    </p>
  </section>
</BaseLayout>
